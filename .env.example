# PMK — environment configuration
# Copy this file to .env and adjust values for your setup.
# .env is gitignored — never commit it.

# Port the monitor (control plane API) listens on
MONITOR_PORT=8000

# Port the kernel (execution plane API) listens on
KERNEL_PORT=8002

# Port the Next.js frontend listens on
PORT=3000

# URL the Next.js proxy uses to reach the monitor
# Change the host if the backend runs on a different machine
API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Cloud provider API keys
# API keys are never stored in the database — the server reads them from here.
# Set only the keys for providers you use. Leave unused entries blank or remove them.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=

# llama-server binary path (only needed for local models)
# LLAMA_SERVER_PATH=/usr/bin/llama-server
