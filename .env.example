# PMK — environment configuration
# Copy this file to .env and adjust values for your setup.
# .env is gitignored — never commit it.

# Port the monitor (control plane API) listens on
MONITOR_PORT=8000

# Port the kernel (execution plane API) listens on
KERNEL_PORT=8002

# Port the Next.js frontend listens on
PORT=3000

# URL the Next.js proxy uses to reach the monitor
# Change the host if the backend runs on a different machine
API_URL=http://localhost:8000
